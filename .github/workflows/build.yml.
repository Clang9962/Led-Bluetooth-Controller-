name: Build Unsigned IPA

on:
  workflow_dispatch: # Allows you to manually trigger it from your iPhone

jobs:
  build:
    runs-on: macos-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Java
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'

      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'

      - name: Install Dependencies
        run: flutter pub get

      - name: Build Unsigned IPA
        run: |
          # 1. Generate configuration files without signing validation
          flutter build ios --release --no-codesign --config-only
          
          # 2. Force Xcode to compile without any profile or team checks
          cd ios
          xcodebuild -workspace Runner.xcworkspace \
            -scheme Runner \
            -sdk iphoneos \
            -configuration Release \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGNING_ALLOWED=NO \
            CODE_SIGN_IDENTITY="" \
            PROVISIONING_PROFILE_SPECIFIER="" \
            DEVELOPMENT_TEAM="" \
            -allowProvisioningDeviceRegistration
          
          # 3. Package the app bundle into an IPA structure
          cd ..
          mkdir -p build/ios/unsigned/Payload
          cp -r build/ios/iphoneos/Runner.app build/ios/unsigned/Payload/
          cd build/ios/unsigned
          zip -r ../unsigned_app.ipa Payload

      - name: Upload IPA Artifact
        uses: actions/upload-artifact@v4
        with:
          name: unsigned-ipa
          path: build/ios/unsigned_app.ipa

